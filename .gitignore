.env
# Local-only Claude session guide; intentionally not tracked.
CLAUDE.md
__pycache__/
*.pyc
*.egg-info/
build/
.import_linter_cache/
checkpoints/
.ipynb_checkpoints/
output/
references/
documentation/

# Generated run logs from experiments/ are disposable (findings live in PIPELINE_HISTORY old §8).
experiments/*.log

# Generated eval results (per-run CSVs + measurement logs) — project-generated, not source.
eval/out_gt*/
# Generated A/B campaign reports (experiments/ab_eval.py) — project-generated, not source.
experiments/ab_eval/

# Vendored upstream SAM2 example notebooks (~24 MB) — reference only, not project code.
examples/

# data/ contents are not committed (CATMAID-derived + large GT). Track only the
# groundtruth scaffold README. (`data/*` not `data/` so git descends to find the negation.)
data/*
!data/groundtruth/
data/groundtruth/*
!data/groundtruth/README.md
